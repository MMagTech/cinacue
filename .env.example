# ---------------------------------------------------------------------------
# Movie Channel — example environment configuration
# Copy to `.env` and adjust. Never commit your real .env.
# ---------------------------------------------------------------------------

# Application timezone (IANA name). Schedule is stored in UTC, displayed in this.
TZ=America/New_York

# --- Plex (used in a later milestone; safe to leave blank for the foundation) --
PLEX_URL=http://192.168.1.10:32400
PLEX_TOKEN=
PLEX_LIBRARY_NAME=Movies

# Path translation: Plex's view of the file -> this container's mounted path.
# Example:
#   Plex path:      /movies/Back to the Future (1985)/movie.mkv
#   Container path: /media/movies/Back to the Future (1985)/movie.mkv
PLEX_PATH_PREFIX=/movies
LOCAL_PATH_PREFIX=/media/movies

# --- Directories -----------------------------------------------------------
# Persistent config/appdata (SQLite DB, password hash, app secret live here).
CONFIG_DIR=/config
# RAM-backed HLS output directory.
STREAM_DIR=/stream

# --- Admin auth ------------------------------------------------------------
# Set this to a strong password on FIRST run to seed the admin account.
# After the hash is stored in CONFIG_DIR you may remove it.
# There is NO default public admin password.
ADMIN_PASSWORD=

# Shared code friends enter to watch the channel. Leave blank to keep the
# viewer open (LAN use). When set, the viewer page, public API, and the HLS
# stream all require it; wrong entries lock out an IP for 15 minutes.
PUBLIC_ACCESS_CODE=

# --- Encoding defaults (channel-wide) --------------------------------------
# MAX_RESOLUTION: one of original | 1080p | 720p | 480p
MAX_RESOLUTION=1080p
VIDEO_BITRATE_KBPS=8000
AUDIO_BITRATE_KBPS=192
# ENCODER is fixed to h264_nvenc in v1
ENCODER=h264_nvenc
# ENCODER_PRESET: one of fast | balanced | quality
ENCODER_PRESET=balanced

# --- Security / behaviour --------------------------------------------------
# Set true when served over HTTPS (or behind a TLS-terminating reverse proxy)
# so the session cookie is only sent over secure connections.
SESSION_COOKIE_SECURE=false
# Auto-enable the channel on startup (resume streaming after a restart).
CHANNEL_AUTO_START=false
# Warm ffmpeg up this many seconds before a movie's scheduled start so the
# stream is ready at air time. Set 0 to turn pre-roll off.
CHANNEL_PREROLL_SECONDS=30
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
